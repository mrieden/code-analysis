{"id": "c90", "problem": "0981_C", "label": "O(n)", "code": "a = int(input())\ns = {}\nans = 0\nfor i in range(a - 1):\n    v, c = map(int, input().split())\n    if v in s:\n        s[v].append(c)\n    else:\n        s[v] = [c]\n    if c in s:\n        s[c].append(v)\n    else:\n        s[c] = [v]\nc = 0\nfor i in range(1, a + 1):\n    if len(s[i]) > 2:\n        c += 1\n        ans = i\nif c > 1:\n    print(\"No\")\nelif c == 0:\n    print(\"Yes\")\n    print(1)\n    for i in s:\n        if len(s[i]) == 1:\n            print(i, end=\" \")\nelse:\n    print(\"Yes\")\n    print(len(s[ans]))\n    k = []\n    for i in s:\n        if len(s[i]) == 1:\n            k.append(i)\n    for i in k:\n        print(min(ans, i), max(ans, i))\n"}
