{"id": "c123", "problem": "1054_D", "label": "O(n)", "code": "from collections import defaultdict\nn,k = map(int,input().split())\narr = list(map(int,input().split()))\nxors = defaultdict(int)\nxors[0]=1\ncomp = (1<<k)-1\nans = n*(n+1)//2\nxor = 0\nfor a in arr:\n\txor^=a\n\tif xors[xor]>xors[comp^xor]:\n\t\txor^=comp\n\tans-=xors[xor]\n\txors[xor]+=1\nprint(ans)"}
