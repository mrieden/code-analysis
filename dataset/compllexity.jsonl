{"id": "c134", "problem": "1093_C", "label": "O(n)", "code": "n = int(input())\n\nb = list(map(int, input().split()))\na1 = [0]\na2 = [b[0]]\n\nfor x in b[1:]:\n\tnew_a = a1[-1]\n\tif x - new_a > a2[-1]:\n\t\tnew_a = x - a2[-1]\n\tnew_a2 = x - new_a\n\ta1.append(new_a)\n\ta2.append(new_a2)\nprint(*(a1+a2[::-1]))"}
{"id": "c135", "problem": "1098_C", "label": "O(n)", "code": "n, s = map(int, input().split())\nif not 2*n - 1 <= s <= n * (n+1) // 2:\n    print('No')\n    exit()\nprint('Yes')\n\ndef ok(d):\n    dep, cur, sum, m = 2, 1, 1, 0\n    while cur + m < n:\n        m += cur\n        cur = min(n - m, cur * d)\n        sum += cur * dep\n        dep += 1\n    return sum <= s\n\nl, r = 1, n\nwhile l < r:\n    mid = (l+r) // 2\n    if ok(mid):\n        r = mid\n    else:\n        l = mid + 1\n\na, me = [l-1] * (n+1), [_ for _ in range(n+1)]\nsum, low = n * (n+1) // 2, 2\nwhile n > low and sum > s:\n    dest = min(sum-s, n-low)\n    sum -= dest\n    me[n] -= dest\n    a[me[n]+1] += l\n    a[me[n]] -= 1\n    if not a[low]: low += 1\n    n -= 1\nme, l, dg = sorted(me[1:]), 0, 0\nfor i in me[1:]:\n    while me[l] < i-1 or dg == r:\n        dg = 0\n        l += 1\n    print(l+1, end=' ')\n    dg += 1\n"}
