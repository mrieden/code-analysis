{"id": "c84", "problem": "0975_D", "label": "O(n)", "code": "import sys\nif locals()['__file__'][-2:] == 'py':\n    sys.stdin = open('in.txt', 'r')\nfrom sys import stdin\nrl = lambda l: tuple(map(int, l.split()))\nn, a, b = rl(input())\nl = list(map(rl, stdin.readlines()))\nc, d = {}, {}\nr = 0\nfor _, x, y in l:\n    i, j = a * x - y, (x, y)\n    r += c.get(i, 0) - d.get(j, 0)\n    c[i] = c.get(i, 0) + 1\n    d[j] = d.get(j, 0) + 1\nprint(2 * r)\n"}
