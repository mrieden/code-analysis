{"id": "c139", "problem": "1179_A", "label": "O(n)", "code": "from collections import deque\nn, q = map(int, input().split())\na = deque(map(int, input().split()))\nb = []\nm = a.index(max(a))\nfor i in range(m):\n    a0, a1 = a.popleft(), a.popleft()\n    b.append([a0, a1])\n    if a0 < a1:\n        a0, a1 = a1, a0\n    a.appendleft(a0)\n    a.append(a1)\nfor i in range(q):\n    c = int(input())\n    if c <= m:\n        print('{} {}'.format(b[c-1][0], b[c-1][1]))\n    else:\n        c -= m+1\n        c %= n-1\n        print('{} {}'.format(a[0], a[c+1]))\n"}
