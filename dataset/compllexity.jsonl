{"id": "c37", "problem": "1080_C", "label": "O(1)", "code": "t = int(input())\n\ndef getcol(x1, y1, x2, y2):\n    dx = max((x2-x1+1), 0)\n    dy = max((y2-y1+1), 0)\n    b = w = dx*dy//2\n    if dx % 2 and dy % 2:\n        if (x1+y1) % 2:\n            b = b + 1\n        else:\n            w = w + 1\n    return w, b\n\nfor _ in range(t):\n    n, m = map(int, input().split())\n    x1, y1, x2, y2 = map(int, input().split())\n    x3, y3, x4, y4 = map(int, input().split())\n    w, b = getcol(1,1,n,m)\n    w1, b1 = getcol(x1,y1,x2,y2)\n    w2, b2 = getcol(x3,y3,x4,y4)\n    w3, b3 = getcol(max(x1,x3),max(y1,y3),min(x2,x4),min(y2,y4))\n    woff = w-w1-w2+w3\n    boff = b-b1-b2+b3\n    print(woff+w1-w3+b1-b3, boff+w3+b3+b2-b3+w2-w3)\n"}
