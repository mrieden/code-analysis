{"id": "c218", "problem": "1059_B", "label": "O(n^2)", "code": "def isValid(field, y, x):\n\tfor i in range(3):\n\t\tfor j in range(3):\n\t\t\tif i == 1 and j == 1:\n\t\t\t\tcontinue\n\t\t\tif field[y + i][x + j] == '.':\n\t\t\t\treturn False\n\treturn True\ndef fill(field, y, x):\n\tfor i in range(3):\n\t\tfor j in range(3):\n\t\t\tif i == 1 and j == 1:\n\t\t\t\tcontinue\n\t\t\tcur[y + i][x + j] = '#'\nn, m = list(map(int, input().split()))\nsig = []\ncur = []\nfor i in range(n):\n\tsig += [list(input())]\n\tcur += [[\".\"] * m]\n\nfor i in range(n - 2):\n\tfor j in range(m - 2):\n\t\tif isValid(sig, i, j):\n\t\t\tfill(cur, i, j)\n\nif sig == cur:\n\tprint(\"YES\")\nelse:\n\tprint(\"NO\")"}
