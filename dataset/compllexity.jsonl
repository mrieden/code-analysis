{"id": "c127", "problem": "1067_B", "label": "O(n log n)", "code": "from collections import deque\n \nm, k = list(map(int, input().split()))\n \nG = [set() for _ in range(m + 1)]\n \nq, nq = deque(), deque()\n \nfor _ in range(m - 1):\n    u, v = list(map(int, input().split()))\n    G[u].add(v)\n    G[v].add(u)\n \nfor u in range(1, m + 1):\n    if len(G[u]) == 1:\n        q.append(u)\n \nstep = 0\nremoved = 0\nok = True\n \nwhile removed < m - 1:\n    each = {}\n    for u in q:\n        nxt = G[u].pop()\n        G[nxt].remove(u)\n        each[nxt] = each.get(nxt, 0) + 1\n        removed += 1\n        if len(G[nxt]) == 0:\n            break\n        if len(G[nxt]) == 1:\n            nq.append(nxt)\n    if any(v < 3 for k,v in each.items()):\n        ok = False\n        break\n    q, nq = nq, deque()\n    step += 1\n \nif ok and step == k and removed == m - 1:\n    print('Yes')\nelse:\n    print('No')\n"}
{"id": "c128", "problem": "1073_B", "label": "O(n)", "code": "n=int(input())\na=list(map(int,input().split()))\nb=list(map(int,input().split()))\nha={}\nfor i in range(n):\n    ha[a[i]]=i\nremoved=0\nout=\"\"\nfor i in range(n):\n    if ha[b[i]]<removed:\n        out+=\"0 \"\n    else:\n        out+=str(ha[b[i]]-removed+1)+\" \"\n        removed=ha[b[i]]+1\nprint(out[:-1])"}
{"id": "c129", "problem": "1075_B", "label": "O(n log n)", "code": "import sys\n\nn, m = [int(w) for w in input().split()]\nx = [int(w) for w in input().split()]\nt = [int(w) for w in input().split()]\n\nif m == 1:\n    print(n)\n    sys.exit(0)\n\np = []\ntx = []\nfor i in range(n+m):\n    (tx if t[i] == 1 else p).append(x[i])\n\na = [0] * m\ni = 0\nfor pi in p:\n    while i < m-1 and pi > (tx[i]+tx[i+1])/2:\n        i += 1\n    a[i] += 1\n\nprint(\" \".join(str(ai) for ai in a))\n"}
{"id": "c130", "problem": "1082_D", "label": "O(n)", "code": "n = int(input())\na = tuple(map(int, input().split()))\nif n * 2 > sum(a) + 2:\n\tprint(\"NO\")\nelse:\n\tn1 = []\n\ton = []\n\tfor i in range(n):\n\t\tif a[i] != 1:\n\t\t\tn1.append(i)\n\t\telse:\n\t\t\ton.append(i)\n\tprint(\"YES\", len(n1) + min(2, len(on)) - 1)\n\tprint(n - 1)\n\tn1it = iter(n1)\n\tnext(n1it)\n\tfor v, u in zip(n1, n1it):\n\t\tprint(v + 1, u + 1)\n\tif on:\n\t\tprint(on.pop() + 1, n1[-1] + 1)\n\tif on:\n\t\tprint(on.pop() + 1, n1[0] + 1)\n\ton = iter(on)\n\tfor n11 in n1:\n\t\tfor i in range(a[n11] - 2):\n\t\t\ttry:\n\t\t\t\tprint(n11 + 1, next(on) + 1)\n\t\t\texcept StopIteration:\n\t\t\t\tbreak\n\t\telse:\n\t\t\tcontinue\n\t\tbreak\n"}
